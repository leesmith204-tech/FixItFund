# ─────────────────────────────────────────────────────────────
#  FixItFund Proxy — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git — it contains your secret API key.
# ─────────────────────────────────────────────────────────────

# Your Anthropic API key — get it from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the server listens on (default: 3000)
PORT=3000

# Comma-separated list of allowed frontend origins (no trailing slash)
# In development: http://localhost:3000
# In production:  https://www.fixitfund.com,https://fixitfund.com
ALLOWED_ORIGINS=http://localhost:3000

# Max AI requests per IP per minute (default: 30)
RATE_LIMIT_PER_MIN=30

# Set to "production" on your live server
NODE_ENV=development
